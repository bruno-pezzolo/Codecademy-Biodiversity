# .gitignore for Codecademy-Biodiversity
# Note: data/raw and data/processed are intentionally NOT ignored so they can be tracked here.

# Jupyter and notebook checkpoints
.ipynb_checkpoints/
*.ipynb_checkpoints

# Virtual environments
.venv/
env/
venv/
.env/

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class

# Byte-compiled / optimized / DLL files
*.pyc
*.pyo
*.pyd

# Distribution / packaging
build/
dist/
*.egg-info/

# Logs and outputs
*.log
outputs/
figures/

# OS files
.DS_Store

# Editor directories
.vscode/
.idea/

# Temporary files
*.swp
*~
